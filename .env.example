# Canonical site origin for WalletConnect metadata (optional; defaults to current host or https://cobagold.com)
# VITE_SITE_URL=https://cobagold.com

# Reown (WalletConnect) Project ID — REQUIRED for the Connect Wallet QR code to appear.
# Without this, tapping a wallet will not show a scannable QR.
# 1. Go to https://dashboard.reown.com
# 2. Create a project and copy the Project ID
# 3. Paste it below and restart the dev server
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional: set to 1 to see WalletConnect/connection errors in the browser console
# VITE_APPKIT_DEBUG=1

# Optional: live gold spot price for the "9.6g -> USDT" comparison
# Copy this file to .env.local and set your key (MetalAPI free tier: https://metalapi.com/pricing)
# Note: VITE_* values are embedded in the built JS — treat as a public client key; rotate if leaked.
# VITE_METALAPI_KEY=your_key_here

# Gold NFT (USDT mint) — set after you deploy contracts/CobaGoldBackedNFT.sol
# VITE_GOLD_NFT_CONTRACT=0xYourDeployedNftContract
# Optional: override USDT (defaults to mainnet USDT when chain = Ethereum mainnet)
# VITE_USDT_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7

# --- Auto-sync NFT mint price to live gold (Vercel server only — never VITE_ prefix on the key) ---
# Same math as the homepage: PAXG/XAUT (+ optional MetalAPI). Cron: vercel.json → /api/sync-gold-nft-price hourly.
# GOLD_NFT_SYNC_PRIVATE_KEY=0x...   # MUST be the NFT contract owner; pays ETH gas; keep secret
# CRON_SECRET=long_random_string     # Vercel sends Authorization: Bearer <this> on cron runs; set in Vercel env
# GOLD_NFT_CONTRACT=0x...            # optional if VITE_GOLD_NFT_CONTRACT is already set (server reads both)
# ETHEREUM_RPC_URL=https://...       # optional; default public RPC if unset
# METALAPI_KEY=...                   # optional; or reuse VITE_METALAPI_KEY on Vercel for the cron
