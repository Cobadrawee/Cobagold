{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!assets/|api/).*)", "destination": "/index.html" }],
  "crons": [{ "path": "/api/sync-gold-nft-price", "schedule": "0 * * * *" }],
  "headers": [
    {
      "source": "/nft/metadata/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" }
      ]
    }
  ]
}
